# ============================================
# Agent Builder Dashboard - Environment Variables
# ============================================

# ============================================
# Application Configuration
# ============================================

# Node environment (production/development)
NODE_ENV=production

# Application URL (used for redirects and webhooks)
APP_URL=https://dashboard.yourdomain.com
APP_URL_HTTP=http://dashboard.yourdomain.com

# API URL (for frontend to call backend)
NEXT_PUBLIC_API_URL=https://dashboard.yourdomain.com/api

# ============================================
# Server Configuration
# ============================================

# Port for Next.js app
PORT=3000
HOST=0.0.0.0

# ============================================
# Stripe Configuration (TEST MODE BY DEFAULT)
# ============================================

# Stripe API Keys - Get from https://dashboard.stripe.com/apikeys
# NOTE: Using test keys by default - switch to live keys for production
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here

# Stripe Webhook Secret - Get from https://dashboard.stripe.com/webhooks
# Run: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price ID - Create product in Stripe Dashboard
# https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_your_price_id_here

# Stripe Metered Billing
STRIPE_METER_EVENT_NAME=agent_usage

# Usage-based billing tiers
STRIPE_USAGE_TIER_1_LIMIT=10000
STRIPE_USAGE_TIER_2_LIMIT=50000
STRIPE_USAGE_TIER_1_COST=0
STRIPE_USAGE_TIER_2_COST=0.001
STRIPE_USAGE_TIER_3_COST=0.0005

# ============================================
# Domain & Nginx Configuration
# ============================================

# Your domain (without subdomain)
DOMAIN=yourdomain.com

# Domain suffix for agent subdomains
DOMAIN_SUFFIX=yourdomain.com

# Base port range for agents
PORT_RANGE_START=3001
PORT_RANGE_END=3999

# Nginx paths
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled

# ============================================
# Agent Storage
# ============================================

# Directory where generated agents are stored
AGENTS_DIR=/opt/agents

# Port allocation file
PORT_ALLOCATION_FILE=/opt/agents/port-allocation.json

# ============================================
# Docker Configuration
# ============================================

# Docker socket path (for docker-compose)
DOCKER_SOCKET=/var/run/docker.sock

# Docker Compose project name
COMPOSE_PROJECT_NAME=agent-builder

# ============================================
# Security
# ============================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl
NEXTAUTH_URL=https://dashboard.yourdomain.com

# Optional: Admin credentials (implement auth as needed)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=your_hashed_password_here

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
ENABLE_STRIPE=true
ENABLE_AGENT_DEPLOYMENT=true
ENABLE_DOCKER=true
ENABLE_NGINX_AUTO_CONFIG=true

# Debug mode (disable in production)
DEBUG=false

# ============================================
# Logging & Monitoring
# ============================================

# Log level (debug/info/warn/error)
LOG_LEVEL=info

# Log directory
LOG_DIR=/var/log/agent-builder

# ============================================
# Rate Limiting
# ============================================

# API rate limits
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Database (Optional - for future use)
# ============================================

# If using a database, configure here
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_builder
# Or for SQLite
# DATABASE_URL=file:./data/agent_builder.db

# ============================================
# External Services
# ============================================

# GitHub Token (for version control of agents)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=agents

# ============================================
# Example Values (Replace with real values)
# ============================================

# After copying this file to .env.local, update with real values:
#
# STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnop
# STRIPE_WEBHOOK_SECRET=whsec_abcdefghijklmnopqrstuvwxyz
# STRIPE_PRICE_ID=price_1234567890abcdefghijklmnop
# DOMAIN=example.com
# NEXTAUTH_SECRET=changeme1234567890abcdefghijklmnop
#
# To generate NEXTAUTH_SECRET:
# openssl rand -base64 32
#
# To get Stripe keys:
# https://dashboard.stripe.com/apikeys
#
# To set up Stripe CLI for local webhook testing:
# stripe listen --forward-to localhost:3000/api/stripe/webhook